# Backend configuration — copy to .env and adjust. Never commit real secrets.

# SQLAlchemy database URL.
# Local docker-compose uses the "db" service hostname.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/inventory

# Comma-separated list of allowed frontend origins for CORS.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Create tables automatically on startup (handy for the demo / assessment).
AUTO_CREATE_TABLES=true

# Seed demo products/customers on startup.
SEED_ON_STARTUP=true
