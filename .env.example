# Root environment for docker-compose. Copy to .env and adjust as needed.
# No real secrets here — defaults are for local development only.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory

# --- Backend ---
# Origins allowed by CORS (the frontend served at :3000 via docker, :5173 via vite dev).
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SEED_ON_STARTUP=true

# --- Frontend (build-time) ---
# URL the browser uses to reach the backend API.
VITE_API_URL=http://localhost:8000
